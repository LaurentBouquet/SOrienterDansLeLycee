{% extends 'base.html.twig' %}

{% block title %}Boussole{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            {# Page Header #}
            <div class="text-center mb-4">
                <h1 class="h3">
                    <i class="fa-solid fa-compass me-2" aria-hidden="true"></i>
                    Boussole
                </h1>
                <p class="text-muted">Orientez-vous dans le bâtiment</p>
            </div>

            {# Compass Card #}
            <div class="card">
                <div class="card-body text-center py-5">
                    <div class="compass-wrapper mb-4">
                        <img id="compass-bg"
                             src="{{ asset('images/compass_bg.png') }}"
                             class="compass-bg"
                             alt="Fond boussole">
                        <img src="{{ asset('images/compass_arrow.png') }}"
                             class="compass-arrow"
                             alt="Flèche boussole">
                    </div>

                    <p id="status" class="text-muted mb-2">En attente des capteurs…</p>
                    <p id="directions" class="h4 fw-bold mb-4">--</p>

                    <button id="enableCompass" class="btn btn-primary">
                        <i class="fa-solid fa-location-crosshairs me-2" aria-hidden="true"></i>
                        Activer la boussole
                    </button>
                </div>
            </div>

            {# Back Link #}
            <div class="text-center mt-4">
                <a href="{{ path('app_index') }}" class="text-muted">
                    <i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>
                    Retour à l'accueil
                </a>
            </div>

        </div>
    </div>
</div>

<script>
    const compassBg = document.getElementById('compass-bg');
    const status = document.getElementById('status');
    const directionsEl = document.getElementById('directions');
    const btn = document.getElementById('enableCompass');

    let lastHeading = null;
    const smoothing = 0.15;

    function normalize(angle) {
        return (angle + 360) % 360;
    }

    function shortestAngle(from, to) {
        let diff = to - from;
        if (diff > 180) diff -= 360;
        if (diff < -180) diff += 360;
        return diff;
    }

    function headingToDirection(angle) {
        const dirs = ['N', 'NE', 'E', 'SE', 'S', 'SO', 'O', 'NO'];
        const index = Math.round(angle / 45) % 8;
        return dirs[index];
    }

    function updateCompass(heading) {
        if (lastHeading !== null) {
            const delta = shortestAngle(lastHeading, heading);
            heading = lastHeading + delta * smoothing;
        }

        lastHeading = normalize(heading);
        compassBg.style.transform = `rotate(${-lastHeading}deg)`;

        status.textContent = `Nord approx. : ${lastHeading.toFixed(1)}°`;
        directionsEl.textContent = headingToDirection(lastHeading);
    }

    btn.addEventListener('click', async () => {
        if (
            typeof DeviceOrientationEvent !== 'undefined' &&
            typeof DeviceOrientationEvent.requestPermission === 'function'
        ) {
            const permission = await DeviceOrientationEvent.requestPermission();
            if (permission !== 'granted') {
                status.textContent = 'Permission refusée';
                return;
            }
        }

        window.addEventListener('deviceorientation', (event) => {
            let heading = null;

            if (event.webkitCompassHeading !== undefined) {
                heading = event.webkitCompassHeading;
            }

            if (heading !== null) {
                updateCompass(heading);
            } else {
                status.textContent = 'Capteur non disponible';
            }
        }, true);

        btn.style.display = 'none';
    });
</script>
{% endblock %}
