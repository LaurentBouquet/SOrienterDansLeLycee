{% extends 'base.html.twig' %}

{% block title %}Boussole{% endblock %}

{% block body %}
<style>
    body {
        background: #f8f9fa;
        font-family: Arial, sans-serif;
    }

    .container {
        margin-top: 50px;
        text-align: center;
    }

    .compass-wrapper {
        position: relative;
        width: 240px;
        height: 240px;
        margin: 20px auto;
    }

    .compass-circle {
        position: absolute;
        inset: 0;
        border: 4px solid #0d6efd;
        border-radius: 50%;
    }

    .north-label {
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        font-weight: bold;
        color: #0d6efd;
        font-size: 1.2rem;
    }

    .compass-arrow {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 55px;
        transform-origin: bottom center;
        transform: translate(-50%, -50%) rotate(0deg);
        transition: transform 0.2s linear;
    }

    .graduation {
        position: absolute;
        width: 2px;
        height: 10px;
        background-color: #0d6efd;
        top: 0;
        left: 50%;
        margin-left: -1px;
        transform-origin: 50% 120px;
    }

    #status {
        margin-top: 15px;
        font-size: 14px;
        color: #555;
    }
</style>

<div class="container">
    <h1>Boussole</h1>

    <div class="compass-wrapper">
        <div class="compass-circle"></div>
        <div class="north-label">N</div>

        <!-- Graduations tous les 30° -->
        {% for i in 0..11 %}
            <div class="graduation" style="transform: rotate({{ i*30 }}deg);"></div>
        {% endfor %}

        <img
            id="arrow"
            src="{{ asset('images/arrow.jpg') }}"
            class="compass-arrow"
            alt="Flèche boussole"
        >
    </div>

    <div id="status">En attente des capteurs…</div>
</div>

<script>
    const arrow = document.getElementById('arrow');
    const status = document.getElementById('status');

    window.addEventListener(
        'deviceorientationabsolute',
        (event) => {
            if (event.alpha !== null) {
                const heading = event.alpha;

                arrow.style.transform =
                    `translate(-50%, -50%) rotate(${-heading}deg)`;

                status.textContent =
                    `Degré exact : ${heading.toFixed(1)}° | absolute: ${event.absolute}`;
            } else {
                status.textContent = 'Capteur non disponible';
            }
        },
        true
    );
</script>
{% endblock %}
