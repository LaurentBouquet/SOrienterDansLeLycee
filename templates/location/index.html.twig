{% extends 'base.html.twig' %}

{% block title %}Administration - Lieux{% endblock %}

{% block body %}
<div class="container py-4">

    {# Page Header #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">
                <i class="fa-solid fa-location-dot me-2" aria-hidden="true"></i>
                Gestion des lieux
            </h1>
            <p class="text-muted mb-0">Gérez les points de navigation du bâtiment</p>
        </div>
        <a href="{{ path('app_location_new') }}" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2" aria-hidden="true"></i>
            Ajouter un lieu
        </a>
    </div>

    {# Quick Links #}
    <div class="mt-4">
        <a href="{{ path('app_connection_index') }}" class="text-muted">
            <i class="fa-solid fa-arrow-right me-1" aria-hidden="true"></i>
            Gérer les connexions
        </a>
    </div>
    <br>

    {# Locations Table Card #}
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>
                <i class="fa-solid fa-list me-2" aria-hidden="true"></i>
                Liste des lieux
            </span>
            <span class="badge bg-secondary">{{ locations|length }} lieu{{ locations|length > 1 ? 'x' : '' }}</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="ps-3">Nom</th>
                            <th scope="col">Étage</th>
                            <th scope="col">Type</th>
                            <th scope="col">Référence</th>
                            <th scope="col">Image</th>
                            <th scope="col" class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for location in locations %}
                        <tr>
                            <td class="ps-3 fw-medium">{{ location.name }}</td>
                            <td>
                                <span class="badge bg-body-secondary text-body">
                                    <i class="fa-solid fa-stairs me-1" aria-hidden="true"></i>
                                    {{ location.floor }}
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-primary-soft text-body">{{ location.type }}</span>
                            </td>
                            <td class="text-muted">{{ location.reference ?: '—' }}</td>
                            <td>
                                {% if location.imageUrl %}
                                    <img src="{{ location.imageUrl }}" 
                                         alt="Image de {{ location.name }}"
                                         class="rounded img-thumbnail-sm">
                                {% else %}
                                    <span class="text-muted small">
                                        <i class="fa-regular fa-image me-1" aria-hidden="true"></i>
                                        Aucune
                                    </span>
                                {% endif %}
                            </td>
                            <td class="text-end pe-3">
                                <a href="{{ path('app_location_show', {'id': location.id}) }}" 
                                   class="btn btn-sm btn-outline-secondary me-1"
                                   title="Voir">
                                    <i class="fa-solid fa-eye" aria-hidden="true"></i>
                                </a>
                                <a href="{{ path('app_location_edit', {'id': location.id}) }}" 
                                   class="btn btn-sm btn-outline-primary me-1"
                                   title="Modifier">
                                    <i class="fa-solid fa-pen" aria-hidden="true"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fa-solid fa-inbox fa-2x mb-2 d-block" aria-hidden="true"></i>
                                Aucun lieu enregistré
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
