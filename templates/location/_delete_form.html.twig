<form method="post" action="{{ path('app_location_delete', {'id': location.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce lieu ? Cette action est irréversible.');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ location.id) }}">
    <button type="submit" class="btn btn-danger">
        <i class="fa-solid fa-trash me-2" aria-hidden="true"></i>
        Supprimer ce lieu
    </button>
</form>
