{% extends 'base.html.twig' %}

{% block title %}Administration - {{ location.name }}{% endblock %}

{% block body %}
<div class="container py-4">

    {# Page Header #}
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="{{ path('app_location_index') }}">Lieux</a></li>
                <li class="breadcrumb-item active" aria-current="page">{{ location.name }}</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0">
                <i class="fa-solid fa-location-dot me-2" aria-hidden="true"></i>
                {{ location.name }}
            </h1>
            <a href="{{ path('app_location_edit', {'id': location.id}) }}" class="btn btn-primary">
                <i class="fa-solid fa-pen me-2" aria-hidden="true"></i>
                Modifier
            </a>
        </div>
    </div>

    <div class="row">
        {# Details Card #}
        <div class="col-12 col-lg-8">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fa-solid fa-info-circle me-2" aria-hidden="true"></i>
                    Détails du lieu
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <tbody>
                            <tr>
                                <th scope="row" class="ps-3 w-25">ID</th>
                                <td>{{ location.id }}</td></td>
                            </tr>
                            <tr>
                                <th scope="row" class="ps-3">Nom</th>
                                <td class="fw-medium">{{ location.name }}</td>
                            </tr>
                            <tr>
                                <th scope="row" class="ps-3">Étage</th>
                                <td>
                                    <span class="badge bg-light text-dark">
                                        <i class="fa-solid fa-stairs me-1" aria-hidden="true"></i>
                                        {{ location.floor }}
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th scope="row" class="ps-3">Type</th>
                                <td>
                                    <span class="badge bg-primary-soft text-dark">{{ location.type }}</span>
                                </td>
                            </tr>
                            <tr>
                                <th scope="row" class="ps-3">Référence</th>
                                <td>{{ location.reference ?: '-' }}</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            {# Image Card #}
            {% if location.imageUrl %}
            <div class="card">
                <div class="card-header">
                    <i class="fa-solid fa-image me-2" aria-hidden="true"></i>
                    Image du lieu
                </div>
                <div class="card-body text-center">
                    <img src="{{ location.imageUrl }}" 
                         alt="Image de {{ location.name }}"
                         class="img-fluid rounded img-thumbnail-md">
                </div>
            </div>
            {% endif %}
        </div>

        {# Sidebar Actions #}
        <div class="col-12 col-lg-4">
            <div class="card">
                <div class="card-header">
                    <i class="fa-solid fa-bolt me-2" aria-hidden="true"></i>
                    Actions rapides
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="{{ path('app_location_edit', {'id': location.id}) }}" class="btn btn-outline-primary">
                            <i class="fa-solid fa-pen me-2" aria-hidden="true"></i>
                            Modifier ce lieu
                        </a>
                        <a href="{{ path('app_location_index') }}" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-list me-2" aria-hidden="true"></i>
                            Retour à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
