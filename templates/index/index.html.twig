{% extends 'base.html.twig' %}

{% block title %}S'Orienter Dans Le Lycée - Accueil{% endblock %}

{% block body %}
<main class="min-vh-100 d-flex flex-column">
    {# Hero Section #}
    <section class="flex-grow-1 d-flex align-items-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-8 text-center py-5">

                    {# Icon #}
                    <div class="mb-4">
                        <i class="fa-solid fa-compass fa-4x text-primary" aria-hidden="true"></i>
                    </div>

                    {# Main Title #}
                    <h1 class="display-4 mb-4">Bienvenue sur S'Orienter Dans Le Lycée</h1>

                    {# Description #}
                    <p class="lead text-muted mb-5">
                        Trouvez facilement votre chemin dans l'établissement.
                        Indiquez votre destination et laissez-vous guider pas à pas,
                        où que vous soyez.
                    </p>

                    {# Primary CTA (Call to Action) #}
                    <a href="{{ path('app_algo_new') }}" class="btn btn-primary btn-lg px-5 py-3">
                        <i class="fa-solid fa-location-arrow me-2" aria-hidden="true"></i>
                        Commencer la navigation
                    </a>

                    {# Reassurance text #}
                    <p class="text-muted mt-4 small">
                        Simple, rapide et accessible à tous.
                    </p>

                </div>
            </div>
        </div>
    </section>

    {# Footer #}
    <footer class="py-3 text-center">
        <small class="text-muted">© {{ "now"|date("Y") }} S'Orienter Dans Le Lycée</small>
    </footer>
</main>
{% endblock %}
