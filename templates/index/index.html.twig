{% extends 'base.html.twig' %}

{% block title %}S'Orienter Dans Le Lycée - Accueil{% endblock %}

{% block body %}
<main class="min-vh-100 d-flex flex-column">
    {# Top Bar #}
    <header class="py-3">
        <div class="container">
            <div class="d-flex justify-content-end align-items-center gap-2">
                {# Dark Mode Toggle #}
                <button 
                    type="button" 
                    class="btn btn-outline-secondary btn-sm" 
                    id="theme-toggle"
                    aria-label="Basculer le mode sombre"
                    title="Changer de thème"
                >
                    <i class="fa-solid fa-moon" aria-hidden="true"></i>
                </button>

                {% if app.user %}
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa-solid fa-cog me-1" aria-hidden="true"></i>
                            Administration
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="{{ path('app_location_index') }}">
                                    <i class="fa-solid fa-location-dot me-2" aria-hidden="true"></i>
                                    Gestion des lieux
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="{{ path('app_connection_index') }}">
                                    <i class="fa-solid fa-diagram-project me-2" aria-hidden="true"></i>
                                    Gestion des connexions
                                </a>
                            </li>
                        </ul>
                    </div>
                    <a href="{{ logout_path() }}" class="btn btn-outline-secondary btn-sm">
                        <i class="fa-solid fa-sign-out-alt me-1" aria-hidden="true"></i>
                        Déconnexion
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn-outline-secondary btn-sm">
                        <i class="fa-solid fa-user me-1" aria-hidden="true"></i>
                        Espace admin
                    </a>
                {% endif %}
            </div>
        </div>
    </header>

    {# Hero Section #}
    <section class="flex-grow-1 d-flex align-items-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-8 text-center py-5">

                    {# Icon #}
                    <div class="mb-4">
                        <i class="fa-solid fa-compass fa-4x text-primary" aria-hidden="true"></i>
                    </div>

                    {# Main Title #}
                    <h1 class="display-4 mb-4">Bienvenue sur S'Orienter Dans Le Lycée</h1>

                    {# Description #}
                    <p class="lead text-muted mb-5">
                        Trouvez facilement votre chemin dans l'établissement.
                        Indiquez votre destination et laissez-vous guider pas à pas,
                        où que vous soyez.
                    </p>

                    {# Primary CTA (Call to Action) #}
                    <a href="{{ path('app_algo_new') }}" class="btn btn-primary btn-lg px-5 py-3">
                        <i class="fa-solid fa-location-arrow me-2" aria-hidden="true"></i>
                        Commencer la navigation
                    </a>

                    {# Reassurance text #}
                    <p class="text-muted mt-4 small">
                        Simple, rapide et accessible à tous.
                    </p>

                </div>
            </div>
        </div>
    </section>

    {# Footer #}
    <footer class="py-3 text-center">
        <small class="text-muted">© {{ "now"|date("Y") }} S'Orienter Dans Le Lycée</small>
    </footer>
</main>
{% endblock %}
