{% extends 'base.html.twig' %}

{% block title %}Connexion - Administration{% endblock %}

{% block body %}
<main class="min-vh-100 d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">

                {# Logo / Brand #}
                <div class="text-center mb-4">
                    <i class="fa-solid fa-compass fa-3x text-primary mb-3" aria-hidden="true"></i>
                    <h1 class="h4">S'Orienter Dans Le Lycée</h1>
                    <p class="text-muted small">Espace administration</p>
                </div>

                {# Login Card #}
                <div class="card">
                    <div class="card-header text-center">
                        <i class="fa-solid fa-lock me-2" aria-hidden="true"></i>
                        Connexion
                    </div>
                    <div class="card-body p-4">

                        {# Error Alert #}
                        {% if error %}
                            <div class="alert alert-danger" role="alert">
                                <i class="fa-solid fa-circle-exclamation me-2" aria-hidden="true"></i>
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        {# Already logged in #}
                        {% if app.user %}
                            <div class="alert alert-primary" role="alert">
                                <i class="fa-solid fa-check-circle me-2" aria-hidden="true"></i>
                                Vous êtes connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>
                            </div>
                            <div class="d-grid gap-2">
                                <a href="{{ path('app_location_index') }}" class="btn btn-primary">
                                    <i class="fa-solid fa-cog me-2" aria-hidden="true"></i>
                                    Accéder à l'administration
                                </a>
                                <a href="{{ logout_path() }}" class="btn btn-outline-secondary">
                                    <i class="fa-solid fa-sign-out-alt me-2" aria-hidden="true"></i>
                                    Se déconnecter
                                </a>
                            </div>
                        {% else %}
                            {# Login Form #}
                            <form method="post">
                                <div class="mb-3">
                                    <label for="username" class="form-label">
                                        <i class="fa-solid fa-envelope me-1" aria-hidden="true"></i>
                                        Adresse email
                                    </label>
                                    <input type="email" 
                                           name="_username" 
                                           id="username" 
                                           class="form-control form-control-lg" 
                                           value="{{ last_username }}" 
                                           autocomplete="email" 
                                           placeholder="admin@example.com"
                                           required 
                                           autofocus>
                                </div>

                                <div class="mb-4">
                                    <label for="password" class="form-label">
                                        <i class="fa-solid fa-key me-1" aria-hidden="true"></i>
                                        Mot de passe
                                    </label>
                                    <input type="password" 
                                           name="_password" 
                                           id="password" 
                                           class="form-control form-control-lg" 
                                           autocomplete="current-password" 
                                           placeholder="••••••••"
                                           required>
                                </div>

                                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="fa-solid fa-sign-in-alt me-2" aria-hidden="true"></i>
                                        Se connecter
                                    </button>
                                </div>
                            </form>
                        {% endif %}

                    </div>
                </div>

                {# Links #}
                <div class="text-center mt-4">
                    <a href="{{ path('app_register') }}" class="text-muted d-block mb-2">
                        <i class="fa-solid fa-user-plus me-1" aria-hidden="true"></i>
                        Créer un compte
                    </a>
                    <a href="{{ path('app_index') }}" class="text-muted">
                        <i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>
                        Retour à l'accueil
                    </a>
                </div>

            </div>
        </div>
    </div>
</main>
{% endblock %}
