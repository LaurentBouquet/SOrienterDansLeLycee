<form method="post" action="{{ path('app_connection_delete', {'id': connection.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette connexion ? Cette action est irréversible.');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ connection.id) }}">
    <button type="submit" class="btn btn-danger">
        <i class="fa-solid fa-trash me-2" aria-hidden="true"></i>
        Supprimer cette connexion
    </button>
</form>
