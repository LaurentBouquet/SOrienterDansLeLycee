{% extends 'base.html.twig' %}

{% block title %}Administration - Connexion{% endblock %}

{% block body %}
<div class="container py-4">

    {# Page Header #}
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="{{ path('app_connection_index') }}">Connexions</a></li>
                <li class="breadcrumb-item active" aria-current="page">{{ connection.locationA.name }} ↔ {{ connection.locationB.name }}</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0">
                <i class="fa-solid fa-diagram-project me-2" aria-hidden="true"></i>
                {{ connection.locationA.name }} ↔ {{ connection.locationB.name }}
            </h1>
            <a href="{{ path('app_connection_edit', {'id': connection.id}) }}" class="btn btn-primary">
                <i class="fa-solid fa-pen me-2" aria-hidden="true"></i>
                Modifier
            </a>
        </div>
    </div>

    <div class="row">
        {# Details Card #}
        <div class="col-12 col-lg-8">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fa-solid fa-info-circle me-2" aria-hidden="true"></i>
                    Détails de la connexion
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <tbody>
                            <tr>
                                <th scope="row" class="ps-3 w-25">ID</th>
                                <td>{{ connection.id }}</td>
                            </tr>
                            <tr>
                                <th scope="row" class="ps-3">Lieu A</th>
                                <td class="fw-medium">{{ connection.locationA.name }}</td>
                            </tr>
                            <tr>
                                <th scope="row" class="ps-3">Lieu B</th>
                                <td class="fw-medium">{{ connection.locationB.name }}</td>
                            </tr>
                            <tr>
                                <th scope="row" class="ps-3">Poids</th>
                                <td>
                                    <span class="badge bg-body-secondary text-body">
                                        <i class="fa-solid fa-weight-hanging me-1" aria-hidden="true"></i>
                                        {{ connection.weight }}
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th scope="row" class="ps-3">Accessible PMR</th>
                                <td>
                                    {% if connection.pmr %}
                                        <span class="badge bg-success">
                                            <i class="fa-solid fa-wheelchair me-1" aria-hidden="true"></i>
                                            Oui
                                        </span>
                                    {% else %}
                                        <span class="badge bg-body-secondary text-body-secondary">Non</span>
                                    {% endif %}
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            {# Instructions Card #}
            <div class="card">
                <div class="card-header">
                    <i class="fa-solid fa-signs-post me-2" aria-hidden="true"></i>
                    Instructions de navigation
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-12 col-md-6 mb-3 mb-md-0">
                            <h6 class="text-muted mb-2">
                                <i class="fa-solid fa-arrow-right me-1" aria-hidden="true"></i>
                                {{ connection.locationA.name }} → {{ connection.locationB.name }}
                            </h6>
                            <p class="mb-0">{{ connection.instructionAtoB ?: 'Aucune instruction' }}</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <h6 class="text-muted mb-2">
                                <i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>
                                {{ connection.locationB.name }} → {{ connection.locationA.name }}
                            </h6>
                            <p class="mb-0">{{ connection.instructionBtoA ?: 'Aucune instruction' }}</p>
                        </div>
                    </div>
                </div>
            </div>

            {# Images Card #}
            {% if connection.imageAtoB or connection.imageBtoA %}
            <div class="card">
                <div class="card-header">
                    <i class="fa-solid fa-image me-2" aria-hidden="true"></i>
                    Images de navigation
                </div>
                <div class="card-body">
                    <div class="row">
                        {% if connection.imageAtoB %}
                        <div class="col-12 col-md-6 mb-3 mb-md-0 text-center">
                            <h6 class="text-muted mb-2">
                                <i class="fa-solid fa-arrow-right me-1" aria-hidden="true"></i>
                                {{ connection.locationA.name }} → {{ connection.locationB.name }}
                            </h6>
                            <img src="/images/connection/{{ connection.imageAtoB }}" 
                                 alt="Image {{ connection.locationA.name }} vers {{ connection.locationB.name }}"
                                 class="img-fluid rounded img-thumbnail-md">
                        </div>
                        {% endif %}
                        {% if connection.imageBtoA %}
                        <div class="col-12 col-md-6 text-center">
                            <h6 class="text-muted mb-2">
                                <i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>
                                {{ connection.locationB.name }} → {{ connection.locationA.name }}
                            </h6>
                            <img src="/images/connection/{{ connection.imageBtoA }}" 
                                 alt="Image {{ connection.locationB.name }} vers {{ connection.locationA.name }}"
                                 class="img-fluid rounded img-thumbnail-md">
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}
        </div>

        {# Sidebar Actions #}
        <div class="col-12 col-lg-4">
            <div class="card">
                <div class="card-header">
                    <i class="fa-solid fa-bolt me-2" aria-hidden="true"></i>
                    Actions rapides
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="{{ path('app_connection_edit', {'id': connection.id}) }}" class="btn btn-outline-primary">
                            <i class="fa-solid fa-pen me-2" aria-hidden="true"></i>
                            Modifier cette connexion
                        </a>
                        <a href="{{ path('app_connection_index') }}" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-list me-2" aria-hidden="true"></i>
                            Retour à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
