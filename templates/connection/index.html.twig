{% extends 'base.html.twig' %}

{% block title %}Administration - Connexions
{% endblock %}

{% block body %}
	<div
		class="container py-4">

		{# Page Header #}
		<div class="d-flex justify-content-between align-items-center mb-4">
			<div>
				<h1 class="h3 mb-1">
					<i class="fa-solid fa-diagram-project me-2" aria-hidden="true"></i>
					Gestion des connexions
				</h1>
				<p class="text-muted mb-0">Gérez les liens entre les lieux (arêtes du graphe)</p>
			</div>
			<a href="{{ path('app_connection_new') }}" class="btn btn-primary">
				<i class="fa-solid fa-plus me-2" aria-hidden="true"></i>
				Ajouter une connexion
			</a>
		</div>

		{# Quick Links #}
		<div class="mt-4">
			<a href="{{ path('app_location_index') }}" class="text-muted">
				<i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>
				Gérer les lieux
			</a>
		</div>
		<br>

		{# Connections Table Card #}
		<div class="card">
			<div class="card-header d-flex justify-content-between align-items-center">
				<span>
					<i class="fa-solid fa-list me-2" aria-hidden="true"></i>
					Liste des connexions
				</span>
				<span class="badge bg-secondary">{{ connections|length }}
					connexion{{ connections|length > 1 ? 's' : '' }}</span>
			</div>
			<div class="card-body p-0">
				<div class="table-responsive">
					<table class="table table-hover align-middle mb-0">
						<thead class="table-light">
							<tr>
								<th scope="col" class="ps-3">Lieu A</th>
								<th scope="col">Lieu B</th>
								<th scope="col">Poids</th>
								<th scope="col">PMR</th>
								<th scope="col">Instruction A→B</th>
								<th scope="col">Instruction B→A</th>
								<th scope="col" class="text-end pe-3">Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for connection in connections %}
								<tr>
									<td class="ps-3 fw-medium">{{ connection.locationA.name }}</td>
									<td class="fw-medium">{{ connection.locationB.name }}</td>
									<td>
										<span class="badge bg-light text-dark">
											<i class="fa-solid fa-weight-hanging me-1" aria-hidden="true"></i>
											{{ connection.weight }}
										</span>
									</td>
									<td>
										{% if connection.pmr %}
											<span class="badge bg-success">
												<i class="fa-solid fa-wheelchair me-1" aria-hidden="true"></i>
												Oui
											</span>
										{% else %}
											<span class="badge bg-danger">
												<i class="fa-solid fa-wheelchair me-1" aria-hidden="true"></i>
												Non
											</span>
										{% endif %}
									</td>
									<td class="small text-muted">{{ connection.instructionAtoB|length > 40 ? connection.instructionAtoB|slice(0, 40) ~ '…' : connection.instructionAtoB }}</td>
									<td class="small text-muted">{{ connection.instructionBtoA|length > 40 ? connection.instructionBtoA|slice(0, 40) ~ '…' : connection.instructionBtoA }}</td>
									<td class="text-end pe-3">
										<a href="{{ path('app_connection_show', {'id': connection.id}) }}" class="btn btn-sm btn-outline-secondary me-1" title="Voir">
											<i class="fa-solid fa-eye" aria-hidden="true"></i>
										</a>
										<a href="{{ path('app_connection_edit', {'id': connection.id}) }}" class="btn btn-sm btn-outline-primary me-1" title="Modifier">
											<i class="fa-solid fa-pen" aria-hidden="true"></i>
										</a>
									</td>
								</tr>
							{% else %}
								<tr>
									<td colspan="7" class="text-center text-muted py-4">
										<i class="fa-solid fa-inbox fa-2x mb-2 d-block" aria-hidden="true"></i>
										Aucune connexion enregistrée
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
