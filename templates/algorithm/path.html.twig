{% extends 'base.html.twig' %}

{% block title %}Itinéraire
{% endblock %}

{% block body %}
	<div class="container-fluid py-4">
		<div
			class="row g-4">

			{# Instructions Panel - Left Side #}
			<div class="col-12 col-lg-4 col-xl-3">
				<div class="card">
					<div class="card-header">
						<h5 class="mb-0">
							<button class="btn btn-link text-decoration-none text-reset w-100 text-start p-0 collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#instructionsCollapse" aria-expanded="false" aria-controls="instructionsCollapse">
								<i class="fa-solid fa-list-check me-2" aria-hidden="true"></i>
								Instructions
								<i class="fa-solid fa-chevron-down float-end mt-1" aria-hidden="true"></i>
							</button>
						</h5>
					</div>
					<div id="instructionsCollapse" class="collapse">
						<div class="card-body p-0">
							{% if path is not empty %}
								<ol class="list-group list-group-flush list-group-numbered">
									{% for step in path %}
										<li class="list-group-item d-flex justify-content-between align-items-start">
											<div class="ms-2 me-auto">
												<div class="fw-bold">{{ step.location }}</div>
												{% if step.instruction %}
													<small class="text-muted">{{ step.instruction }}</small>
												{% endif %}
											</div>
										</li>
									{% endfor %}
								</ol>
							{% else %}
								<div class="p-4 text-center text-muted">
									<i class="fa-solid fa-triangle-exclamation fa-2x mb-2" aria-hidden="true"></i>
									<p class="mb-0">Aucun chemin trouvé</p>
								</div>
							{% endif %}
						</div>
					</div>
				</div>
			</div>

			{# Visual Steps - Right Side #}
			<div class="col-12 col-lg-8 col-xl-9">
				<div class="card h-100">
					<div class="card-header d-flex justify-content-between align-items-center">
						<h5 class="mb-0 flex-grow-1">
							<button class="btn btn-link text-decoration-none text-reset w-100 text-start p-0" type="button" data-bs-toggle="collapse" data-bs-target="#parcoursCollapse" aria-expanded="true" aria-controls="parcoursCollapse">
								<i class="fa-solid fa-images me-2" aria-hidden="true"></i>
								Parcours visuel
								{% if path is not empty %}
									<span class="badge bg-primary ms-2">
										{{ path|length }}
										étape{{ path|length > 1 ? 's' : '' }}
									</span>
								{% endif %}
								<i class="fa-solid fa-chevron-down float-end mt-1" aria-hidden="true"></i>
							</button>
						</h5>
					</div>
					<div id="parcoursCollapse" class="collapse show">
						<div class="card-body">
							{% if path is not empty %}
								<div class="row g-3">
									{% for step in path %}
										<div class="col-12 col-md-6 col-xl-4">
											<div class="card h-100">
												{% if step.image %}
													<img src="{{ asset('images/connection/' ~ step.image) }}" class="card-img-top img-step" alt="Vue de {{ step.location }}">
												{% else %}
													<div class="card-img-top bg-light d-flex align-items-center justify-content-center img-step">
														<i class="fa-solid fa-image fa-2x text-muted" aria-hidden="true"></i>
													</div>
												{% endif %}
												<div class="card-body">
													<h6 class="card-title mb-1">
														<span class="badge bg-primary me-2">{{ loop.index }}</span>
														{{ step.location }}
													</h6>
													{% if step.instruction %}
														<p class="card-text small text-muted mb-0">{{ step.instruction }}</p>
													{% endif %}
												</div>
											</div>
										</div>
									{% endfor %}
								</div>
							{% else %}
								<div class="d-flex align-items-center justify-content-center h-100 text-muted content-area-sm">
									<div class="text-center">
										<i class="fa-solid fa-route fa-4x mb-3" aria-hidden="true"></i>
										<p class="mb-0">Aucun itinéraire à afficher</p>
									</div>
								</div>
							{% endif %}
						</div>
					</div>
				</div>
			</div>

		</div>

		{# Action Buttons - Bottom of Page #}
		<div class="row mt-4">
			<div class="col-12">
				<div class="d-flex justify-content-center gap-3">
					<a href="{{ path('app_index') }}" class="btn btn-outline-secondary">
						<i class="fa-solid fa-arrow-left me-2" aria-hidden="true"></i>
						Retour à l'accueil
					</a>
					<a href="{{ path('app_algo_new') }}" class="btn btn-primary">
						<i class="fa-solid fa-rotate-left me-2" aria-hidden="true"></i>
						Nouveau trajet
					</a>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
