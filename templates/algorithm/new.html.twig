{% extends 'base.html.twig' %}

{% block title %}Navigation - Trouver mon chemin
{% endblock %}

{% block body %}
	<div class="container-fluid py-4">
		<div
			class="row g-4">

			{# Control Panel - Left Side #}
			<div class="col-12 col-lg-4 col-xl-3">
				<div class="card">
					<div class="card-header">
						<h5 class="mb-0">
							<i class="fa-solid fa-route me-2" aria-hidden="true"></i>
							Planifier mon trajet
						</h5>
					</div>
					<div class="card-body">
						{{ form_start(form, {'attr': {'class': 'navigation-form'}}) }}


						{# Starting Point #}
						<div class="mb-4">
							<label for="{{ form.start.vars.id }}" class="form-label">
								<i class="fa-solid fa-circle text-primary me-2" aria-hidden="true"></i>
								Point de départ
							</label>
							{# Starting Point Filter #}
							<div class="mb-1">
								<select id="start-floor-filter" class="form-select form-select-lg" onchange="filterStartLocations()">
									<option value="">Tous les étages</option>
									<option value="-1">Sous-sol</option>
									<option value="0">Rez-de-chaussée</option>
									<option value="1">Étage 1</option>
									<option value="2">Étage 2</option>
									<option value="3">Étage 3</option>
								</select>
							</div>
							{{ form_widget(form.start, {'attr': {'class': 'form-select form-select-lg'}}) }}
							{{ form_errors(form.start) }}
						</div>


						{# Destination #}
						<div class="mb-4">
							<label for="{{ form.end.vars.id }}" class="form-label">
								<i class="fa-solid fa-location-dot text-primary me-2" aria-hidden="true"></i>
								Destination
							</label>
							{# Destination Filter #}
							<div class="mb-1">
								<select id="end-floor-filter" class="form-select form-select-lg" onchange="filterEndLocations()">
									<option value="">Tous les étages</option>
									<option value="-1">Sous-sol</option>
									<option value="0">Rez-de-chaussée</option>
									<option value="1">Étage 1</option>
									<option value="2">Étage 2</option>
									<option value="3">Étage 3</option>
								</select>
							</div>
							{{ form_widget(form.end, {'attr': {'class': 'form-select form-select-lg'}}) }}
							{{ form_errors(form.end) }}
						</div>

						{# PMR Option #}
						<div class="mb-4">
							<div class="form-check">
								{{ form_widget(form.pmr, {'attr': {'class': 'form-check-input'}}) }}
								{{ form_label(form.pmr, null, {'label_attr': {'class': 'form-check-label'}}) }}
							</div>
							{{ form_errors(form.pmr) }}
						</div>

						{# Submit Button #}
						<div class="d-grid">
							<button type="submit" class="btn btn-primary btn-lg">
								<i class="fa-solid fa-magnifying-glass me-2" aria-hidden="true"></i>
								Trouver mon chemin
							</button>
						</div>

						{{ form_end(form) }}
					</div>

					{# Help Text #}
					<div class="card-footer text-muted small">
						<i class="fa-solid fa-circle-info me-1" aria-hidden="true"></i>
						Sélectionnez votre position actuelle et votre destination pour obtenir l'itinéraire.
					</div>
				</div>

				{# Back to Home Link #}
				<div class="mt-3 text-center">
					<a href="{{ path('app_index') }}" class="text-muted">
						<i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>
						Retour à l'accueil
					</a>
				</div>
			</div>

			{# Map Area - Right Side #}
			<div class="col-12 col-lg-8 col-xl-9">
				<div class="card h-100">
					<div class="card-header d-flex justify-content-between align-items-center">
						<h5 class="mb-0">
							<i class="fa-solid fa-map me-2" aria-hidden="true"></i>
							Plan du bâtiment
						</h5>
						<span class="badge bg-secondary">
							<i class="fa-solid fa-building me-1" aria-hidden="true"></i>
							Vue d'ensemble
						</span>
					</div>
					<div class="card-body bg-light content-area-lg p-0">
						<img src="{{ asset('images/building_plan.jpg') }}" alt="Plan du bâtiment" class="w-100 h-100" style="display: block;">
					</div>
				</div>
			</div>

		</div>
	</div>

	<script>
		let startOptionsData = [];
		let endOptionsData = [];

		document.addEventListener('DOMContentLoaded', function() {
			// Use Symfony's generated IDs
			const startSelect = document.getElementById('{{ form.start.vars.id }}');
			const endSelect = document.getElementById('{{ form.end.vars.id }}');

			// Store original options
			if (startSelect) {
				startOptionsData = Array.from(startSelect.options).map(option => ({
					value: option.value,
					text: option.text,
					floor: option.dataset.floor,
					type: option.dataset.type
				}));
				console.log('Start options loaded:', startOptionsData.length);
			}

			if (endSelect) {
				endOptionsData = Array.from(endSelect.options).map(option => ({
					value: option.value,
					text: option.text,
					floor: option.dataset.floor,
					type: option.dataset.type
				}));
				console.log('End options loaded:', endOptionsData.length);
			}
		});

		function filterStartLocations() {
			const floorFilter = document.getElementById('start-floor-filter');
			const locationSelect = document.getElementById('{{ form.start.vars.id }}');
			const selectedFloor = floorFilter.value;

			filterLocations(locationSelect, selectedFloor, startOptionsData, 'Sélectionner un lieu de départ');
		}

		function filterEndLocations() {
			const floorFilter = document.getElementById('end-floor-filter');
			const locationSelect = document.getElementById('{{ form.end.vars.id }}');
			const selectedFloor = floorFilter.value;

			filterLocations(locationSelect, selectedFloor, endOptionsData, 'Sélectionner un lieu d\'arrivée');
		}

		function filterLocations(selectElement, floor, optionsData, placeholder) {
			// Store current selection
			const currentValue = selectElement.value;

			// Clear current options
			selectElement.innerHTML = '';

			// Add placeholder
			const placeholderOption = document.createElement('option');
			placeholderOption.value = '';
			placeholderOption.text = placeholder;
			selectElement.appendChild(placeholderOption);

			// Filter and add options
			let hasCurrentValue = false;
			optionsData.forEach(optionData => {
				// Skip empty values
				if (!optionData.value) return;

				// If no floor selected, show all; otherwise filter by floor
				if (!floor || optionData.floor === floor) {
					const option = document.createElement('option');
					option.value = optionData.value;
					option.text = optionData.text;
					option.dataset.floor = optionData.floor;
					option.dataset.type = optionData.type;
					selectElement.appendChild(option);

					if (optionData.value === currentValue) {
						hasCurrentValue = true;
					}
				}
			});

			// Restore selection if still available
			if (hasCurrentValue) {
				selectElement.value = currentValue;
			}
		}
	</script>
{% endblock %}
